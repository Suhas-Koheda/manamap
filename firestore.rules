rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Posts Collection
    match /posts/{postId} {
      function isValidPost(data) {
        return data.type in ['issue', 'explore'] &&
               data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
               data.latitude is number && data.longitude is number &&
               data.createdAt == request.time;
      }

      allow read: if true;
      
      allow create: if isValidId(postId) && 
                      isValidPost(request.resource.data) &&
                      request.resource.data.upvotes == 0 &&
                      request.resource.data.status == 'open';

      allow update: if (
        // Action: Self update (if userId matches)
        (resource.data.userId == request.auth.uid && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['description', 'status', 'title', 'category'])) ||
        // Action: Upvote increment
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvotes']) &&
         request.resource.data.upvotes == resource.data.upvotes + 1)
      );
      
      allow delete: if resource.data.userId == request.auth.uid;
    }

    // Upvotes Collection
    match /upvotes/{upvoteId} {
      allow read: if true;
      allow create: if true; // Local storage handles uniqueness checks for UX, but rules allow writes
    }
  }
}
