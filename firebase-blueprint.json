{
  "entities": {
    "Post": {
      "title": "Post",
      "description": "A civic issue or exploration spot reported by a user.",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["issue", "explore"],
          "description": "The category of the report."
        },
        "title": {
          "type": "string",
          "description": "Title of the post."
        },
        "description": {
          "type": "string",
          "description": "Detailed description."
        },
        "image_url": {
          "type": "string",
          "format": "uri",
          "description": "URL to the uploaded image."
        },
        "latitude": {
          "type": "number",
          "description": "Latitude coordinate."
        },
        "longitude": {
          "type": "number",
          "description": "Longitude coordinate."
        },
        "category": {
          "type": "string",
          "description": "Sub-category (e.g., potholes, garbage)."
        },
        "status": {
          "type": "string",
          "enum": ["open", "resolved"],
          "description": "Current status of the issue."
        },
        "upvotes": {
          "type": "integer",
          "description": "Total count of upvotes."
        },
        "userId": {
          "type": "string",
          "description": "ID of the user who created the post."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when created."
        }
      },
      "required": ["type", "title", "latitude", "longitude", "userId", "createdAt"]
    },
    "Upvote": {
      "title": "Upvote",
      "description": "A record of a user upvoting a post.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "User who voted."
        },
        "postId": {
          "type": "string",
          "description": "Post being voted on."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the vote."
        }
      },
      "required": ["userId", "postId", "createdAt"]
    }
  },
  "firestore": {
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Collection of all issues and exploration spots."
    },
    "/upvotes/{upvoteId}": {
      "schema": "Upvote",
      "description": "Collection to track and prevent duplicate upvotes."
    }
  }
}
